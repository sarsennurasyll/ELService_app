generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  TECHNICIAN
  ADMIN
}

enum OrderStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  ACTIVE
  COMPLETED
  CANCELLED
  DISPUTED
}

enum OfferStatus {
  ACTIVE
  ACCEPTED
  INACTIVE
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  phone        String?
  avatar       String?
  city         String?
  passwordHash String
  role         UserRole

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerOrders    Order[]         @relation("CustomerOrders")
  technicianOrders  Order[]         @relation("TechnicianOrders")
  assignedMasterOrders Order[]      @relation("AssignedMasterOrders")
  offers             Offer[]        @relation("MasterOffers")
  reviewsGiven      Review[]        @relation("ReviewsGiven")
  reviewsReceived   Review[]        @relation("ReviewsReceived")
  messages          Message[]
  conversationsA    Conversation[]  @relation("ConversationUserA")
  conversationsB    Conversation[]  @relation("ConversationUserB")
  notifications     Notification[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

model Order {
  id           String      @id @default(cuid())
  description  String
  address      String?
  price        Decimal?    @db.Decimal(12, 2)
  status       OrderStatus @default(PENDING)
  preferredDate DateTime?

  customerId   String
  technicianId String?
  assignedMasterId String?
  categoryId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer     User          @relation("CustomerOrders", fields: [customerId], references: [id])
  technician   User?         @relation("TechnicianOrders", fields: [technicianId], references: [id])
  assignedMaster User?       @relation("AssignedMasterOrders", fields: [assignedMasterId], references: [id])
  category     Category      @relation(fields: [categoryId], references: [id])
  offers       Offer[]
  review       Review?
  conversation Conversation?
}

model Offer {
  id          String      @id @default(cuid())
  price       Decimal     @db.Decimal(12, 2)
  arrivalTime String
  comment     String?
  status      OfferStatus @default(ACTIVE)
  orderId     String
  masterId    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  master User  @relation("MasterOffers", fields: [masterId], references: [id])

  @@index([orderId])
  @@unique([orderId, masterId])
}

model Review {
  id           String @id @default(cuid())
  rating       Int
  comment      String?

  orderId      String @unique
  customerId   String
  technicianId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order      Order @relation(fields: [orderId], references: [id])
  customer   User  @relation("ReviewsGiven", fields: [customerId], references: [id])
  technician User  @relation("ReviewsReceived", fields: [technicianId], references: [id])
}

model Conversation {
  id     String @id @default(cuid())
  orderId String @unique
  userAId String
  userBId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order    Order     @relation(fields: [orderId], references: [id])
  userA    User      @relation("ConversationUserA", fields: [userAId], references: [id])
  userB    User      @relation("ConversationUserB", fields: [userBId], references: [id])
  messages Message[]
}

model Message {
  id             String @id @default(cuid())
  text           String
  conversationId String
  senderId       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])
}

model Notification {
  id      String  @id @default(cuid())
  title   String
  body    String
  isRead  Boolean @default(false)
  userId  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}
